# Production only (CodeBuild / Amplify) — no trailing slash
# VITE_API_URL=https://api.yourdomain.com
# VITE_SITE_URL=https://www.yourdomain.com

# Dev: do not set VITE_API_URL. Vite proxies /api to the backend.
# VITE_API_PROXY_TARGET=http://localhost:3001

# Production: keep refresh off the public UI (server cron updates the catalog).
# VITE_ALLOW_REFRESH=false
